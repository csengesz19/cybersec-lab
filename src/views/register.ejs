<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title><%= title %> - CyberSec Lab</title>
    <link rel="stylesheet" href="/style.css">
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Orbitron:wght@600;700&display=swap"
      rel="stylesheet"
    >
    <link rel="icon" href="/favicon_io/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/favicon_io/apple-touch-icon.png">
    <link rel="manifest" href="/favicon_io/site.webmanifest">
  </head>
  <body>
    <%- include('partials/siteHeader') %>

    <main class="container">
      <section class="card">
        <h1 class="main-heading">Create account</h1>
        <p>Register a new account for the DataTrains part of the project.</p>
      </section>

      <% if (errorMessage) { %>
        <div class="card error">
          <p><%= errorMessage %></p>
        </div>
      <% } %>

      <section class="card">
        <h2 class="universal">Register</h2>

        <form class="data-form" method="POST" action="/register">
          <input type="hidden" name="nextUrl" value="<%= nextUrl %>">

          <div class="form-row">
            <label for="name">Name:</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              maxlength="100"
              value="<%= formData.name %>"
            >
          </div>

          <div class="form-row">
            <label for="email">Email:</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              maxlength="100"
              value="<%= formData.email %>"
            >
          </div>

          <div class="form-row">
            <label for="password">Password:</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="6"
            >
          </div>

          <div class="form-row">
            <label for="passwordAgain">Password again:</label>
            <input
              type="password"
              id="passwordAgain"
              name="passwordAgain"
              required
              minlength="6"
            >
          </div>

          <button type="submit" class="primary game-btn">Register</button>
        </form>

        <p style="margin-top: 14px;">
          Already have an account?
          <a class="secondary" href="/login?next=<%= encodeURIComponent(nextUrl) %>">Login here</a>
        </p>
      </section>
    </main>

    <footer>
      <p>Created by <strong> Szabó Csenge </strong> - &copy; CyberSec Lab</p>
    </footer>
  </body>
</html>